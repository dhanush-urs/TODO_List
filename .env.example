# Database Configuration
# Railway automatically provides DATABASE_URL or individual MYSQL* variables.
# For local development, set DATABASE_URL in your .env file.
# Format: mysql+pymysql://user:password@host:port/database

DATABASE_URL=mysql+pymysql://root:password@localhost:3306/todo_app

# Railway-provided variables (Alternative)
MYSQLHOST=
MYSQLPORT=3306
MYSQLUSER=
MYSQLPASSWORD=
MYSQLDATABASE=

# Port (automatically injected by Railway)
PORT=8000

